<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <!-- ── Top info bar ───────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- Score -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_score"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvScoreValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_value"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="1200" />
        </LinearLayout>

        <!-- Level -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_level"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvLevelValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textColor="@color/text_value"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Lines -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_lines"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
            <TextView
                android:id="@+id/tvLinesValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_value"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Next piece + Pause -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_next"
                android:textColor="@color/text_label"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1" />
            <com.example.tetris.NextPieceView
                android:id="@+id/nextPieceView"
                android:layout_width="60dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <!-- Pause button -->
        <Button
            android:id="@+id/btnPause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_pause"
            android:textSize="12sp"
            android:backgroundTint="@color/btn_bg"
            android:textColor="@color/text_value"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

    </LinearLayout>

    <!-- ── Game board (takes all remaining vertical space) ───────────────── -->
    <com.example.tetris.TetrisView
        android:id="@+id/tetrisView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ── Controls ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="10dp">

        <!-- Top row: Rotate + Hard Drop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="6dp">

            <Button
                android:id="@+id/btnRotate"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_rotate"
                android:textSize="20sp"
                android:backgroundTint="@color/btn_action"
                android:textColor="@color/text_value" />

            <Button
                android:id="@+id/btnHardDrop"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/btn_hard_drop"
                android:textSize="20sp"
                android:backgroundTint="@color/btn_action"
                android:textColor="@color/text_value" />

        </LinearLayout>

        <!-- Bottom row: Left + Soft-Drop + Right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnLeft"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_left"
                android:textSize="22sp"
                android:backgroundTint="@color/btn_bg"
                android:textColor="@color/text_value" />

            <Button
                android:id="@+id/btnDown"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_down"
                android:textSize="22sp"
                android:backgroundTint="@color/btn_bg"
                android:textColor="@color/text_value" />

            <Button
                android:id="@+id/btnRight"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/btn_right"
                android:textSize="22sp"
                android:backgroundTint="@color/btn_bg"
                android:textColor="@color/text_value" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
